## rename to .env

## Environment Variables


# Path to the user's Beets configuration directory
BEETSDIR=/.config/beets  #path to your beets config.yaml

# Path to your music library
LIBRARY_PATH=/path/to/yor/music

# Add any other environment-specific settings here
FLASK_PORT=

# Enable Flask's debugger/reloader (development only). Leave unset/false in
# production: the debugger exposes an interactive console (RCE) on errors.
FLASK_DEBUG=false
